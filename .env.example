# Copy to `.env` in this folder. Variables are loaded when you start the API (not by "running" this file).

FLASK_ENV=development
PORT=5000
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret

DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/document_manager?charset=utf8mb4
# On Railway you can set MYSQL_PUBLIC_URL / DATABASE_PUBLIC_URL / MYSQL_URL / MYSQLHOST+… (see config.py order).
# DATABASE_URL wins if multiple are set — remove a stale DATABASE_URL if you rely on MYSQL_PUBLIC_URL.
# MYSQL_SSL=auto (default): TLS for *.rlwy.net public proxy; MYSQL_SSL=1 forces TLS; MYSQL_SSL=0 disables.
# Railway often gives mysql://... — config rewrites that to mysql+pymysql (PyMySQL); you can paste as-is.
# For local dev against Railway MySQL, use the **public** URL from the MySQL plugin Variables (not internal).
# Error 1045 = wrong user/password or URL mangled; URL-encode special characters in the password (@ : / ? # %).
# SQLite: relative paths are resolved under the backend/ folder (not the shell cwd), so the same
# DB file is used no matter where you run `python app.py` from. Prefer MySQL in production.
# DATABASE_URL=sqlite:///instance/dev.db
# AUTO_CREATE_MYSQL_DATABASE=true

FRONTEND_URL=http://localhost:3000

# Brevo (https://developers.brevo.com/) — verification + welcome emails for admin-created users
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=noreply@your-verified-domain.com
# BREVO_SENDER_NAME=Document Manager
MAX_UPLOAD_MB=50
STORAGE_PATH=storage/uploads

# Groq (https://console.groq.com/keys) — optional AI re-ranking for GET /api/v1/ai/search
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_AI_SEARCH_CANDIDATE_LIMIT=40
# GROQ_TIMEOUT_SEC=45

# Start the server from the backend folder:
#   python app.py
# Or:  flask run --host=0.0.0.0 --port=5000
